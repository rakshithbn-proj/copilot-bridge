{
  "name": "copilot-bridge-server",
  "displayName": "Copilot Bridge Server",
  "description": "HTTP bridge that exposes VS Code + GitHub Copilot Chat to external Python scripts and agents",
  "version": "5.2.2",
  "publisher": "rakshithbn",
  "license": "MIT",
  "homepage": "https://github.com/rakshithbn-proj/copilot-bridge#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/rakshithbn-proj/copilot-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/rakshithbn-proj/copilot-bridge/issues"
  },
  "keywords": ["copilot", "bridge", "ai", "agent", "python", "automation"],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copilotBridge.start",
        "title": "Copilot Bridge Server: Start Server"
      },
      {
        "command": "copilotBridge.stop",
        "title": "Copilot Bridge Server: Stop Server"
      },
      {
        "command": "copilotBridge.status",
        "title": "Copilot Bridge Server: Show Status"
      }
    ],
    "configuration": {
      "title": "Copilot Bridge Server",
      "properties": {
        "copilotBridge.port": {
          "type": "number",
          "default": 5150,
          "description": "Port for the HTTP server"
        },
        "copilotBridge.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Auto-start server when VS Code opens"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --allow-missing-repository",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.0.0"
  }
}
